generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  logoUrl     String?
  accent      String         @default("#d71920")
  background  String         @default("#050505")
  settings    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  categories  Category[]
  expenses    Expense[]
  orders      Order[]
  musicRequests MusicRequest[]
  products    Product[]
  tables      Table[]
  sessions    TableSession[]
  users       User[]
  waiterCalls WaiterCall[]
}

model User {
  id             String       @id @default(cuid())
  restaurantId   String
  name           String
  email          String?
  passwordHash   String?
  role           UserRole     @default(STAFF)
  createdAt      DateTime     @default(now())
  assignedTables Table[]      @relation("WaiterTables")
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  waiterCalls    WaiterCall[] @relation("WaiterCalls")

  @@unique([restaurantId, email])
}

model Table {
  id               String         @id @default(cuid())
  restaurantId     String
  number           Int
  qrToken          String         @unique
  status           TableStatus    @default(AVAILABLE)
  currentSessionId String?
  assignedWaiterId String?
  orders           Order[]
  assignedWaiter   User?          @relation("WaiterTables", fields: [assignedWaiterId], references: [id])
  currentSession   TableSession?  @relation("CurrentTableSession", fields: [currentSessionId], references: [id])
  restaurant       Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sessions         TableSession[] @relation("TableSessions")
  musicRequests    MusicRequest[]
  waiterCalls      WaiterCall[]

  @@unique([restaurantId, number])
  @@index([restaurantId, qrToken])
  @@index([assignedWaiterId])
}

model TableSession {
  id           String             @id @default(cuid())
  restaurantId String
  tableId      String
  status       TableSessionStatus @default(ACTIVE)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  orders       Order[]
  activeOn     Table[]            @relation("CurrentTableSession")
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table              @relation("TableSessions", fields: [tableId], references: [id], onDelete: Cascade)
  users        TableSessionUser[]
  musicRequests MusicRequest[]
  waiterCalls  WaiterCall[]

  @@index([restaurantId, tableId, status])
}

model TableSessionUser {
  id        String       @id @default(cuid())
  sessionId String
  name      String
  clientId  String
  active    Boolean      @default(true)
  joinedAt  DateTime     @default(now())
  orders    Order[]
  session   TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, clientId])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  active       Boolean    @default(true)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([restaurantId, name])
}

model Product {
  id           String      @id @default(cuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String
  imageUrl     String?
  priceCents   Int
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]
  category     Category?   @relation(fields: [categoryId], references: [id])
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Order {
  id            String            @id @default(cuid())
  restaurantId  String
  tableId       String
  sessionId     String
  sessionUserId String?
  customerName  String
  status        OrderStatus       @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  session       TableSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionUser   TableSessionUser? @relation(fields: [sessionUserId], references: [id])
  table         Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([restaurantId, sessionId, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitCents   Int
  notes       String?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model Expense {
  id           String     @id @default(cuid())
  restaurantId String
  description  String
  category     String?
  amountCents  Int
  occurredAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, occurredAt])
}

model MusicRequest {
  id           String             @id @default(cuid())
  restaurantId String
  tableId      String
  sessionId    String
  customerName String
  title        String
  artist       String?
  notes        String?
  status       String             @default("OPEN")
  createdAt    DateTime           @default(now())
  playedAt     DateTime?
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table              @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session      TableSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([restaurantId, status, createdAt])
  @@index([tableId, status])
  @@index([sessionId, status])
}

model WaiterCall {
  id               String           @id @default(cuid())
  restaurantId     String
  tableId          String
  sessionId        String
  customerName     String
  type             WaiterCallType
  status           WaiterCallStatus @default(OPEN)
  createdAt        DateTime         @default(now())
  resolvedAt       DateTime?
  assignedWaiterId String?
  assignedWaiter   User?            @relation("WaiterCalls", fields: [assignedWaiterId], references: [id])
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  session          TableSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  table            Table            @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([assignedWaiterId, status])
}

enum UserRole {
  OWNER
  MANAGER
  KITCHEN
  WAITER
  STAFF
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  WAITING_BILL
  CLOSED
}

enum TableSessionStatus {
  ACTIVE
  CLOSING
  CLOSED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum WaiterCallType {
  WAITER
  BILL
}

enum WaiterCallStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}
