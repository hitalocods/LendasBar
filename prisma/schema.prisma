generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  logoUrl     String?
  accent      String         @default("#d71920")
  background  String         @default("#050505")
  settings    Json           @default("{}")
  users       User[]
  tables      Table[]
  sessions    TableSession[]
  categories  Category[]
  products    Product[]
  orders      Order[]
  waiterCalls WaiterCall[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model User {
  id             String       @id @default(cuid())
  restaurantId   String
  name           String
  email          String?
  role           UserRole     @default(STAFF)
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  assignedTables Table[]      @relation("WaiterTables")
  waiterCalls    WaiterCall[] @relation("WaiterCalls")
  createdAt      DateTime     @default(now())

  @@unique([restaurantId, email])
}

model Table {
  id               String         @id @default(cuid())
  restaurantId     String
  number           Int
  qrToken          String         @unique
  status           TableStatus    @default(AVAILABLE)
  currentSessionId String?
  assignedWaiterId String?
  restaurant       Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  assignedWaiter   User?          @relation("WaiterTables", fields: [assignedWaiterId], references: [id], onDelete: SetNull)
  sessions         TableSession[] @relation("TableSessions")
  currentSession   TableSession?  @relation("CurrentTableSession", fields: [currentSessionId], references: [id], onDelete: SetNull)
  orders           Order[]
  waiterCalls      WaiterCall[]

  @@unique([restaurantId, number])
  @@index([restaurantId, qrToken])
  @@index([assignedWaiterId])
}

model TableSession {
  id           String             @id @default(cuid())
  restaurantId String
  tableId      String
  status       TableSessionStatus @default(ACTIVE)
  openedAt     DateTime           @default(now())
  closedAt     DateTime?
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table              @relation("TableSessions", fields: [tableId], references: [id], onDelete: Cascade)
  activeOn     Table[]            @relation("CurrentTableSession")
  users        TableSessionUser[]
  orders       Order[]
  waiterCalls  WaiterCall[]

  @@index([restaurantId, tableId, status])
}

model TableSessionUser {
  id        String       @id @default(cuid())
  sessionId String
  name      String
  clientId  String
  active    Boolean      @default(true)
  session   TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orders    Order[]
  joinedAt  DateTime     @default(now())

  @@unique([sessionId, clientId])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  active       Boolean    @default(true)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([restaurantId, name])
}

model Product {
  id           String      @id @default(cuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String
  imageUrl     String?
  priceCents   Int
  active       Boolean     @default(true)
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category     Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Order {
  id            String            @id @default(cuid())
  restaurantId  String
  tableId       String
  sessionId     String
  sessionUserId String?
  customerName  String
  status        OrderStatus       @default(PENDING)
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table         Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session       TableSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionUser   TableSessionUser? @relation(fields: [sessionUserId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([restaurantId, sessionId, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitCents   Int
  notes       String?
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model WaiterCall {
  id               String           @id @default(cuid())
  restaurantId     String
  tableId          String
  sessionId        String
  customerName     String
  type             WaiterCallType
  status           WaiterCallStatus @default(OPEN)
  assignedWaiterId String?
  restaurant       Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table            Table            @relation(fields: [tableId], references: [id], onDelete: Cascade)
  session          TableSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignedWaiter   User?            @relation("WaiterCalls", fields: [assignedWaiterId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  resolvedAt       DateTime?

  @@index([assignedWaiterId, status])
}

enum UserRole {
  OWNER
  MANAGER
  KITCHEN
  WAITER
  STAFF
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  WAITING_BILL
  CLOSED
}

enum TableSessionStatus {
  ACTIVE
  CLOSING
  CLOSED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum WaiterCallType {
  WAITER
  BILL
}

enum WaiterCallStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}
